FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

#include "pvfr.txt"

internalField   uniform #codeStream
 {
           code
           #{
              scalar hyd = 0.0104;
              scalar TI = 0.0200;

              // Convert LPM to m^3/s
              scalar Q = $vfr * 0.001 / 60.0;

              // Compute cross-sectional area
              scalar area = M_PI * Foam::pow(hyd / 2.0, 2);

              // Velocity magnitude (m/s)
              scalar vel = Q / area;

              scalar result = (3.0 * Foam::pow(vel * TI, 2)) / 2.0;

              os  << result;
           #};
 };


boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            fixedValue; //kLowReWallFunction;
        value           uniform 0;
    }

}


